{
    "hosting": {
        "public": "frontend",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            {
                "source": "/api/send-feedback",
                "function": "sendFeedback"
            },
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    },
    "functions": {
        "source": "backend/functions",
        "runtime": "nodejs18"
    }
}